import customtkinter as ctk
import secrets
import string
import os
import datetime

# =========================
# APPLICATION SETTINGS
# =========================

# Set dark mode appearance
ctk.set_appearance_mode("dark")

# Set default color theme
ctk.set_default_color_theme("blue")

# Length of the generated password
PASSWORD_LENGTH = 40


# =========================
# CHARACTER SETS
# =========================

# Lowercase letters
LOWER = string.ascii_lowercase

# Uppercase letters
UPPER = string.ascii_uppercase

# Numbers
DIGITS = string.digits

# Symbols accepted by most websites
SYMBOLS = "!@#$%^&*()-_=+"

# Combine all characters
ALL = LOWER + UPPER + DIGITS + SYMBOLS


# =========================
# DESKTOP PATH SETTINGS
# =========================

# Get path to user's Desktop
desktop_path = os.path.join(os.path.expanduser("~"), "Desktop")

# Folder that will be created on the Desktop
folder_path = os.path.join(desktop_path, "MyPasswords")

# File where passwords will be stored
file_path = os.path.join(folder_path, "passwords.txt")


# =========================
# PASSWORD GENERATOR
# =========================

def generate_password():
    """
    Generates a strong password and displays it in the GUI.
    """

    password = []

    # Ensure at least one of each character type
    password.append(secrets.choice(LOWER))
    password.append(secrets.choice(UPPER))
    password.append(secrets.choice(DIGITS))
    password.append(secrets.choice(SYMBOLS))

    # Fill the rest of the password length
    for i in range(PASSWORD_LENGTH - 4):
        password.append(secrets.choice(ALL))

    # Shuffle characters for randomness
    secrets.SystemRandom().shuffle(password)

    # Convert list to string
    password = "".join(password)

    # Display password in the input box
    password_box.delete(0, "end")
    password_box.insert(0, password)


# =========================
# COPY PASSWORD
# =========================

def copy_password():
    """
    Copies the generated password to the clipboard.
    """

    password = password_box.get()

    if password == "":
        return

    app.clipboard_clear()
    app.clipboard_append(password)


# =========================
# SAVE PASSWORD
# =========================

def save_password():
    """
    Saves the password to a file inside a folder on the Desktop.
    """

    password = password_box.get()

    if password == "":
        return

    # Create folder if it doesn't exist
    if not os.path.exists(folder_path):
        os.makedirs(folder_path)

    # Save password with date
    with open(file_path, "a") as file:

        file.write("Date: " + str(datetime.datetime.now()) + "\n")
        file.write(password + "\n")
        file.write("---------------------\n")


# =========================
# GUI WINDOW
# =========================

# Create main application window
app = ctk.CTk()

# Window title
app.title("Secure Password Generator")

# Window size
app.geometry("520x300")

# Prevent resizing
app.resizable(False, False)

# Title label
title = ctk.CTkLabel(app, text="Secure Password Generator", font=("Arial", 24))
title.pack(pady=20)

# Password display field
password_box = ctk.CTkEntry(app, width=420, height=40, font=("Arial", 16))
password_box.pack(pady=10)

# Button to generate password
generate_btn = ctk.CTkButton(app, text="Generate Password", command=generate_password)
generate_btn.pack(pady=8)

# Button to copy password
copy_btn = ctk.CTkButton(app, text="Copy Password", command=copy_password)
copy_btn.pack(pady=8)

# Button to save password
save_btn = ctk.CTkButton(app, text="Save Password", command=save_password)
save_btn.pack(pady=8)

# Start the GUI program
app.mainloop()
